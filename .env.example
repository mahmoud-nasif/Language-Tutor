# Runtime mode: development | test | production
APP_ENV=development

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# API bind host and port
HOST=0.0.0.0
PORT=8000

# Compute device preference: cuda | cpu
DEVICE=cuda

# LLM provider selection: ollama | claude
LLM_PROVIDER=ollama

# LLM model identifier used by selected provider
LLM_MODEL=qwen2.5:7b-instruct

# Ollama endpoint reachable from backend container
OLLAMA_BASE_URL=http://ollama:11434

# Required only when LLM_PROVIDER=claude
ANTHROPIC_API_KEY=

# Reserved for Phase 1 model selection
WHISPER_MODEL=small
MIN_AUDIO_MS=300
MAX_AUDIO_MS=30000
PAUSE_THRESHOLD_MS=700

# Reserved for Phase 4/5 persistence and demo mode
DATABASE_URL=sqlite:///data/polyglot.db
DEMO_MODE=false
